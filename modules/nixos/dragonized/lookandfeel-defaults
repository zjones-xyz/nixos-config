[kcminputrc][Mouse]
cursorTheme=Sweet-cursors

[kdeglobals][General]
ColorScheme=Sweet

[kdeglobals][Icons]
Theme=BeautyLine

[kdeglobals][KDE]
ColorScheme=Sweet
LookAndFeelPackage=Dr460nized
widgetStyle=kvantum-dark

[kwinrc][Windows]
BorderlessMaximizedWindows=false

# Fast-subset build (see hosts/pegasus/DECISIONS.md): upstream points this at
# the Sweet-Dark aurorae theme, part of the separate "Sweet KDE" theme suite
# that isn't packaged here — KWin couldn't load a nonexistent theme, which is
# why window minimize/maximize/close controls were missing entirely (no
# decoration loaded at all, not just a different-looking one). Falls back to
# org.kde.breeze, the same decoration already proven working on the
# daily-driver Plasma session.
[kwinrc][org.kde.kdecoration2]
library=org.kde.breeze

[plasmarc][Theme]
name=Dr460nized

[KSplash]
Theme=Dr460nized

[Wallpaper]
Image=Malefor

[kscreenlockerrc][Greeter]
WallpaperPlugin=org.kde.image

# Fast-subset build: upstream points this at /usr/share/wallpapers/... (an
# Arch filesystem path that doesn't exist on NixOS at all). Points at the
# same packaged Malefor wallpaper the desktop background already uses
# successfully (modules/nixos/dragonized/lookandfeel-layout.js).
[kscreenlockerrc][Greeter][Wallpaper][org.kde.image][General]
Image=file:///run/current-system/sw/share/wallpapers/Malefor/contents/images/3840x1920.jpg

[gtk-3.0/settings.ini][Settings]
gtk-theme-name=Sweet-Dark

[.gtkrc-2.0]
gtk-theme-name=Sweet-Dark

[kvantum.kvconfig][General]
theme=Dr460nized
