[kcminputrc][Mouse]
cursorTheme=Sweet-cursors

[kdeglobals][General]
ColorScheme=Sweet

[kdeglobals][Icons]
Theme=BeautyLine

[kdeglobals][KDE]
ColorScheme=Sweet
LookAndFeelPackage=Dr460nized
widgetStyle=kvantum-dark

[kwinrc][Windows]
BorderlessMaximizedWindows=false

# Upstream points this at the Sweet-Dark aurorae theme (part of the separate
# "Sweet KDE" suite). That theme has no reliable git source — every lead
# (EliverLara/Sweet-kde is the *desktoptheme*, not the decoration; the actual
# aurorae SVGs are Pling/KDE-Store-only downloads, and even Garuda's own users
# report this same "missing window decoration" gap on their forum) dead-ended,
# so this uses Klassy instead — packaged in nixpkgs, no provenance risk,
# highly configurable, actively maintained for Plasma 6.
#
# The [org.kde.kdecoration2] config *group* name is legacy/stable — KWin still
# reads "which decoration library" from it even on Plasma 6.6, where the
# actual plugin ABI moved to kdecoration3 (confirmed: both breeze.so and
# klassy.so install to lib/qt-6/plugins/org.kde.kdecoration3/ now). The
# library= value is just the plugin's .so basename, same as org.kde.breeze.
[kwinrc][org.kde.kdecoration2]
library=org.kde.klassy

[plasmarc][Theme]
name=Dr460nized

[KSplash]
Theme=Dr460nized

[Wallpaper]
Image=Malefor

[kscreenlockerrc][Greeter]
WallpaperPlugin=org.kde.image

# Fast-subset build: upstream points this at /usr/share/wallpapers/... (an
# Arch filesystem path that doesn't exist on NixOS at all). Points at the
# same packaged Malefor wallpaper the desktop background already uses
# successfully (modules/nixos/dragonized/lookandfeel-layout.js).
[kscreenlockerrc][Greeter][Wallpaper][org.kde.image][General]
Image=file:///run/current-system/sw/share/wallpapers/Malefor/contents/images/3840x1920.jpg

[gtk-3.0/settings.ini][Settings]
gtk-theme-name=Sweet-Dark

[.gtkrc-2.0]
gtk-theme-name=Sweet-Dark

[kvantum.kvconfig][General]
theme=Dr460nized
